{
  "mcpServers": {
    "excalidraw": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "excalidraw-render"]
    },
    "mcp-mermaid": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-mermaid"]
    },
    "mcp-server-chart": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@antv/mcp-server-chart"]
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest", "--autoConnect", "--channel=beta"]
    }
  }
}
